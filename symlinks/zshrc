#!/usr/bin/env zsh
# Termieter ZSH Configuration
# Lean, fast, no oh-my-zsh dependency

# Load environment variables
source $HOME/.termieter/env

# Load lean base configuration (replaces oh-my-zsh)
[ -f $TRM/zsh/base-lean.sh ] && source $TRM/zsh/base-lean.sh

if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init zsh)"; fi

# bun completions
[ -s "/Users/pieterm/.bun/_bun" ] && source "/Users/pieterm/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
