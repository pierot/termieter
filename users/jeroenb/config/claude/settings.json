{
  "skillListingBudgetFraction": 0.05,
  "permissions": {
    "defaultMode": "auto",
    "additionalDirectories": ["/home/jeroen/.claude/projects"]
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/jeroen/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/home/jeroen/.claude/hooks/context-mode-cache-heal.mjs\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $(0) }'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); exec \"/home/jeroen/.bun/bin/bun\" --env-file /dev/null \"${plugin_dir}src/index.ts\"'"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "worktrunk@worktrunk": true,
    "elixir-lsp@claude-code-elixir": true,
    "mix-format@claude-code-elixir": true,
    "mix-compile@claude-code-elixir": true,
    "mix-credo@claude-code-elixir": true,
    "elixir@claude-code-elixir": true,
    "plannotator@plannotator": true,
    "agent-skills@addy-agent-skills": true,
    "context-mode@context-mode": true
  },
  "extraKnownMarketplaces": {
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "worktrunk": {
      "source": {
        "source": "github",
        "repo": "max-sixty/worktrunk"
      }
    },
    "claude-code-elixir": {
      "source": {
        "source": "github",
        "repo": "georgeguimaraes/claude-code-elixir"
      }
    },
    "plannotator": {
      "source": {
        "source": "github",
        "repo": "backnotprop/plannotator"
      }
    },
    "addy-agent-skills": {
      "source": {
        "source": "github",
        "repo": "addyosmani/agent-skills"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "ultracode": true,
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true
}
