{
  "permissions": {
    "allow": [
      "Bash(awk:*)",
      "Bash(brew:*)",
      "Bash(cat:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(cut:*)",
      "Bash(date:*)",
      "Bash(diff:*)",
      "Bash(docker-compose:*)",
      "Bash(docker:*)",
      "Bash(echo:*)",
      "Bash(fd:*)",
      "Bash(fgrep:*)",
      "Bash(find:*)",
      "Bash(for*)",
      "Bash(git clone:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(make gettext:*)",
      "Bash(make test:*)",
      "Bash(make ts:*)",
      "Bash(make:*)",
      "Bash(mix compile)",
      "Bash(mix ecto.gen.migration:*)",
      "Bash(mix ecto.migrate:*)",
      "Bash(mix format:*)",
      "Bash(mix test:*)",
      "Bash(mix:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(open:*)",
      "Bash(pnpm:*)",
      "Bash(psql -h localhost -U postgres justified -c *)",
      "Bash(pwd:*)",
      "Bash(rg:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(source .env:*)",
      "Bash(source:*)",
      "Bash(tail:*)",
      "Bash(touch:*)",
      "Bash(tr:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "WebFetch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebSearch",
      "mcp__pgedge-postgres__count_rows",
      "mcp__pgedge-postgres__execute_explain",
      "mcp__pgedge-postgres__get_schema_info",
      "mcp__pgedge-postgres__query_database",
      "mcp__plugin_context-mode_context-mode__ctx_batch_execute",
      "mcp__plugin_context-mode_context-mode__ctx_execute",
      "mcp__plugin_context-mode_context-mode__ctx_execute_file",
      "mcp__plugin_context-mode_context-mode__ctx_search"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/pieterm/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $(0) }'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); bun_bin=$(command -v bun 2>/dev/null); [ -z \"$bun_bin\" ] && for b in \"$HOME/.bun/bin/bun\" /opt/homebrew/bin/bun /usr/local/bin/bun; do [ -x \"$b\" ] && bun_bin=\"$b\" && break; done; exec \"$bun_bin\" --env-file /dev/null \"${plugin_dir}src/index.ts\"'"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "elixir-optimization@elixir-claude-optimization": true,
    "frontend-design@claude-plugins-official": true,
    "context-mode@context-mode": true,
    "claude-hud@claude-hud": true,
    "plannotator@plannotator": true
  },
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "plannotator": {
      "source": {
        "source": "github",
        "repo": "backnotprop/plannotator"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high"
}
